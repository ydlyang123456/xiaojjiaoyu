<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StudyCheckStudent"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.StudyCheckStudent.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.StudyCheckStudent.NoActionBar" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false" />

        <activity
            android:name=".ui.search.SearchResultActivity"
            android:exported="false" />

        <activity android:name=".ui.knowledge.KnowledgeActivity"
            android:theme="@style/Theme.StudyCheckStudent" />
        <activity android:name=".ui.pet.PetActivity"
            android:theme="@style/Theme.StudyCheckStudent" />
        <activity android:name=".ui.leaderboard.LeaderboardActivity"
            android:theme="@style/Theme.StudyCheckStudent" />
        <activity android:name=".ui.reader.ReaderActivity"
            android:theme="@style/Theme.StudyCheckStudent.NoActionBar" />
        <activity android:name=".ui.correction.CorrectionActivity"
            android:theme="@style/Theme.StudyCheckStudent" />

        <!-- 家长端Activity -->
        <activity android:name=".ui.parent.BindStudentActivity"
            android:theme="@style/Theme.StudyCheckStudent" />
        <activity android:name=".ui.analysis.AnalysisActivity"
            android:theme="@style/Theme.StudyCheckStudent" />
        <activity android:name=".ui.analysis.AnalysisDetailActivity"
            android:theme="@style/Theme.StudyCheckStudent" />
        <activity android:name=".ui.search.SearchDetailActivity"
            android:theme="@style/Theme.StudyCheckStudent" />

        <!-- 记忆卡片 -->
        <activity android:name=".ui.flashcard.FlashcardActivity"
            android:theme="@style/Theme.StudyCheckStudent" />

        <!-- 宠物对战 -->
        <activity android:name=".ui.battle.BattleActivity"
            android:theme="@style/Theme.StudyCheckStudent" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
